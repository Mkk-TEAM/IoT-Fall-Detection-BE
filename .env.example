NODE_ENV=development
PORT=3000
API_PREFIX=/api/v1
CORS_ORIGIN=*
TRUST_PROXY=false

DATABASE_URL="postgresql://<DB_USER>:<DB_PASSWORD>@127.0.0.1:5432/dadn_db?schema=public"

SALT_ROUNDS=10
JWT_SECRET=<your_jwt_secret_min_32_chars>
JWT_EXPIRES_IN=1h

EMAIL_ENABLED=false
EMAIL_FROM_NAME="IoT Fall Detection"
EMAIL_FROM_ADDRESS=no-reply@iot-fall-detection.local
EMAIL_USER=
EMAIL_APP_PASSWORD=

OTP_EXPIRES_IN_MINUTES=5
OTP_RESEND_INTERVAL_SECONDS=60

MEDIA_BASE_URL=/media
VIDEO_RETENTION_DAYS=3
LOG_RETENTION_DAYS=30

STREAM_SESSION_TTL_SECONDS=300
STUN_URL=stun:stun.l.google.com:19302
EDGE_STREAM_SCHEME=http
EDGE_STREAM_PORT=8081
