{
  "name": "dadn-backend",
  "version": "1.0.0",
  "description": "Backend API for IoT fall detection system for elderly care",
  "main": "server.js",
  "type": "module",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "db:pull": "npx dotenv -e ./.env -- npx prisma db pull",
    "db:generate": "npx dotenv -e ./.env -- npx prisma generate",
    "db:deploy": "npx dotenv -e ./.env -- npx prisma migrate deploy",
    "db:status": "npx dotenv -e ./.env -- npx prisma migrate status",
    "db:studio": "npx dotenv -e ./.env -- npx prisma studio",
    "db:reset": "npx dotenv -e ./.env -- npx prisma migrate reset"
  },
  "keywords": [
    "iot",
    "fall-detection",
    "express",
    "prisma",
    "postgresql"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "bcrypt": "^6.0.0",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "morgan": "^1.10.1",
    "nodemailer": "^8.0.5",
    "pg": "^8.20.0",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1"
  },
  "devDependencies": {
    "dotenv-cli": "^11.0.0",
    "nodemon": "^3.1.14",
    "prisma": "^7.8.0"
  }
}
